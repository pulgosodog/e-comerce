<section class="orders-page" style="max-width:1100px;margin:24px auto;padding:20px">
  <h2>Tus Órdenes</h2>
  <% if (!orders || orders.length === 0) { %>
    <p>No tienes órdenes aún.</p>
  <% } else { %>
    <div class="orders-grid" style="display:flex;flex-direction:column;gap:18px;margin-top:12px">
      <% orders.forEach(function(order){ %>
        <article class="order-card" style="border:1px solid #e9e9e9;padding:16px;border-radius:10px;background:#fff">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <div>
              <div style="font-weight:700">ORDER #<%= order.order_id %></div>
              <div style="color:#666;font-size:13px">Fecha: <%= new Date(order.created_at).toLocaleString() %></div>
            </div>
            <div style="text-align:right">
              <div style="font-weight:700">Total: $<%= order.total %></div>
              <div style="color:#0a8b3a"><%= order.status %></div>
            </div>
          </div>

          <div style="margin-top:12px;border-top:1px solid #f3f3f3;padding-top:12px">
            <% order.items.forEach(function(it){ %>
              <div style="display:flex;gap:12px;align-items:center;padding:10px 0;border-bottom:1px dashed #f0f0f0">
                <img src="<%= it.product && it.product.image_url || '/images/placeholder.png' %>" alt="" style="width:72px;height:72px;object-fit:cover;border-radius:6px" />
                <div style="flex:1">
                  <div style="font-weight:600"><%= it.product ? it.product.name : 'Producto' %></div>
                  <div style="color:#666;font-size:13px">Cant: <%= it.quantity %> &middot; Precio: $<%= it.unit_price %></div>
                </div>
                <div style="min-width:80px;text-align:right">$<%= (it.unit_price * it.quantity).toFixed(2) %></div>
              </div>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>
