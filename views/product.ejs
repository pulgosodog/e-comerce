<section class="product-detail" style="max-width:1100px;margin:24px auto;padding:20px">
  <div style="display:flex;gap:24px;align-items:flex-start;">
    <div style="flex:1;max-width:480px">
      <img src="<%= product.image_url || '/images/placeholder.png' %>" alt="<%= product.name %>" loading="lazy" width="480" height="320" style="width:100%;border-radius:8px;object-fit:cover" onerror="this.onerror=null;this.src='/images/placeholder.png';" />
    </div>
    <div style="flex:1.2">
      <h1 style="margin:0 0 8px"><%= product.name %></h1>
      <p style="color:#666;margin:0 0 12px">Marca: <strong><%= product.brand || 'N/A' %></strong></p>
      <p style="font-size:20px;margin:8px 0">
        <% if (product.is_on_sale && product.price_sale) { %>
          <span style="color:var(--accent);font-weight:700">$<%= product.price_sale %></span>
          <span style="text-decoration:line-through;margin-left:8px;color:#999">$<%= product.price_regular %></span>
        <% } else { %>
          <span style="font-weight:700">$<%= product.price_regular %></span>
        <% } %>
      </p>
      <p style="margin:8px 0;color:<%= product.stock && product.stock > 0 ? '#0a8b3a' : '#d9534f' %>">Stock: <strong><%= product.stock %></strong></p>
      <p style="color:#333;margin-top:12px"><%= product.description %></p>

      <div style="margin-top:16px;display:flex;gap:12px;align-items:center">
        <input id="qty" type="number" value="1" min="1" max="<%= product.stock || 1 %>" style="width:80px;padding:8px;border:1px solid #e0e0e0;border-radius:8px" />
        <button id="add-to-cart-detail" class="btn btn-primary">Añadir al carrito</button>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('add-to-cart-detail').addEventListener('click', async () => {
      const qty = parseInt(document.getElementById('qty').value, 10) || 1;
      try {
        const res = await fetch('/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId: <%= product.product_id %>, quantity: qty }) });
        if (res.ok) {
          const json = await res.json();
          // update cart count in header if present
          const span = document.getElementById('cart-count');
          if (span) span.textContent = json.cart.reduce((s, it) => s + it.quantity, 0);
          alert('Producto agregado al carrito');
          return;
        }
      } catch (err) {
        // fallback to localStorage
      }
      // fallback localStorage
      const local = JSON.parse(localStorage.getItem('cart') || '[]');
      const found = local.find(i => i.productId === <%= product.product_id %>);
      if (found) found.quantity += qty; else local.push({ productId: <%= product.product_id %>, quantity: qty });
      localStorage.setItem('cart', JSON.stringify(local));
      const span = document.getElementById('cart-count'); if (span) span.textContent = local.reduce((s,i)=>s+i.quantity,0);
      alert('Producto agregado al carrito (local)');
    });
  </script>
</section>
