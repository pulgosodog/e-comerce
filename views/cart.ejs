<section class="cart-page" style="max-width:1100px;margin:24px auto;padding:20px">
  <h2>Carrito</h2>
  <% if (!items || items.length === 0) { %>
    <p>Tu carrito está vacío.</p>
  <% } else { %>
    <table style="width:100%;border-collapse:collapse;margin-top:12px">
      <thead>
        <tr style="text-align:left;border-bottom:1px solid #eaeaea">
          <th style="padding:8px">Producto</th>
          <th style="padding:8px">Precio</th>
          <th style="padding:8px">Cantidad</th>
          <th style="padding:8px">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(function(it){ %>
          <tr style="border-bottom:1px solid #f0f0f0">
            <td style="padding:12px;display:flex;gap:12px;align-items:center">
              <img src="<%= it.product.image_url || '/images/placeholder.png' %>" alt="" style="width:80px;height:80px;object-fit:cover;border-radius:6px" />
              <div>
                <div style="font-weight:600"><a href="/product/<%= it.product.product_id %>"><%= it.product.name %></a></div>
                <div style="color:#666;font-size:13px"><%= it.product.brand || '' %></div>
              </div>
            </td>
            <td style="padding:12px">$<%= it.unit_price %></td>
            <td style="padding:12px">
              <form method="post" action="/cart/update" style="display:inline">
                <input type="hidden" name="productId" value="<%= it.product.product_id %>" />
                <input type="number" name="quantity" value="<%= it.quantity %>" min="1" style="width:64px;padding:6px;border:1px solid #ddd;border-radius:6px" />
                <button class="btn btn-outline" type="submit">Actualizar</button>
              </form>
              <form method="post" action="/cart/remove" style="display:inline;margin-left:8px">
                <input type="hidden" name="productId" value="<%= it.product.product_id %>" />
                <button class="btn" type="submit">Eliminar</button>
              </form>
            </td>
            <td style="padding:12px">$<%= (it.unit_price * it.quantity).toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <aside style="margin-top:24px;display:flex;justify-content:flex-end">
      <div style="width:360px;border:1px solid #e9e9e9;padding:16px;border-radius:8px;background:#fff">
        <h4>Totales del carrito</h4>
        <div style="display:flex;justify-content:space-between;padding:6px 0"><span>Subtotal</span><span>$<%= totals.subtotal.toFixed(2) %></span></div>
        <div style="display:flex;justify-content:space-between;padding:6px 0"><span>Impuesto</span><span>$<%= totals.tax.toFixed(2) %></span></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;font-weight:700;border-top:1px solid #eee;margin-top:8px"><span>Total</span><span>$<%= totals.total.toFixed(2) %></span></div>
        <form method="post" action="/cart/checkout">
          <button type="submit" class="btn btn-primary" style="width:100%;margin-top:12px">Finalizar compra</button>
        </form>
      </div>
    </aside>
  <% } %>
</section>
